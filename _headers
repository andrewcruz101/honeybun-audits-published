/*
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains

/audits/*
  Cache-Control: public, max-age=300, must-revalidate
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://api.leadconnectorhq.com https://*.leadconnectorhq.com https://calendly.com; connect-src 'self' https://og.gethoneybun.com; base-uri 'self'; form-action 'none'
